# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Data (large files — never commit full datasets)
# Exception: Montseny patches + annotations ARE committed for replicability
data/*
!data/.gitkeep
!data/montseny/
data/montseny/raw/               # raw ICGC GeoTIFFs (1.3GB, git-ignored)
data/montseny/rasters/           # cached NDVI + CHM rasters (per-patch)
data/montseny/boundary.geojson   # not yet created
!data/montseny/patches/
!data/montseny/patches/**
!data/montseny/patches_metadata.csv
!data/montseny/annotations_raw.json

# Outputs (generated results — never commit)
outputs/*
!outputs/.gitkeep

# Auto-research experiment log (survives git resets, must stay untracked)
autoresearch/results.tsv
autoresearch/run.log

# Trained model checkpoints (large, not committed)
checkpoints/

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.key
credentials.*

# Downloaded model weights (large, re-downloaded on first run)
*.pth
rf-detr-*.pth
