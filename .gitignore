# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Data (large files — never commit full datasets)
data/*
!data/.gitkeep
!data/montseny/
data/montseny/raw/               # raw ICGC GeoTIFFs (1.3GB, git-ignored)
data/montseny/rasters/           # cached NDVI + CHM rasters (per-patch)
data/montseny/lidar/             # cached ICGC LAZ tiles (~400-700 MB each)
data/montseny/patches/           # ignoring images/patches
data/montseny/boundary.geojson   # not yet created
!data/montseny/patches_metadata.csv
data/montseny/annotations_raw.json   # large (~50 MB), should not be in git
data/montseny/annotations_round_*.json  # training round annotations
data/montseny/eval_gold/             # gold evaluation set

# Outputs (generated results — never commit)
outputs/*
!outputs/.gitkeep

# Auto-research experiment log (survives git resets, must stay untracked)
autoresearch/results.tsv
autoresearch/run.log

# Trained model checkpoints (large, not committed)
checkpoints/

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.key
credentials.*

# Downloaded model weights (large, re-downloaded on first run)
*.pth
rf-detr-*.pth

# Images and Media
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.tif
*.tiff
*.webp

# Cache & Logs
.pytest_cache/
.ruff_cache/
.mypy_cache/
lightning_logs/
wandb/
.claude/
*.log
