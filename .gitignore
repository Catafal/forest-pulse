# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Data (large files — never commit full datasets)
data/*
!data/.gitkeep
!data/montseny/
data/montseny/*
!data/montseny/patches_metadata.csv

# Outputs (generated results — never commit)
outputs/*
!outputs/.gitkeep

# Auto-research experiment log (survives git resets, must stay untracked)
autoresearch/results.tsv
autoresearch/run.log

# Trained model checkpoints (large, not committed)
checkpoints/

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.key
credentials.*

# Downloaded model weights (large, re-downloaded on first run)
*.pth
rf-detr-*.pth

# Images and Media
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.tif
*.tiff
*.webp

# Cache & Logs
.pytest_cache/
.ruff_cache/
.mypy_cache/
lightning_logs/
wandb/
.claude/
*.log
