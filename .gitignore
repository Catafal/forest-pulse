# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Data (large files — never commit)
data/*
!data/.gitkeep

# Outputs (generated results — never commit)
outputs/*
!outputs/.gitkeep

# Auto-research experiment log (survives git resets, must stay untracked)
autoresearch/results.tsv
autoresearch/run.log
autoresearch/checkpoints/

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.key
credentials.*
